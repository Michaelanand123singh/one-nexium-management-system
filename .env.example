# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Auth (custom - add your secret)
AUTH_SECRET="your-secret-key"

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Self-hosted file storage (MinIO). Preferred when set.
# STORAGE_DRIVER=minio
# MINIO_ENDPOINT=http://127.0.0.1:9000
# MINIO_ACCESS_KEY=nexiumminio
# MINIO_SECRET_KEY=change-me-minio-secret-min-8-chars
# MINIO_BUCKET=nexium
# MINIO_REGION=us-east-1

# Resend (Email - fallback when no Gmail/SMTP)
RESEND_API_KEY=
EMAIL_FROM=no-reply@yourdomain.com

# Google OAuth — used for (1) Gmail in Inbox and (2) Sign in with Google on login
# Redirect URI: if NEXIUM_APP_URL is set, that base is used; otherwise the request URL. Add the exact redirect URI in Google Cloud Console:
#   Local:   http://localhost:3000/api/auth/google/callback
#   Prod:    https://workspace.onenexium.com/api/auth/google/callback  (must match NEXIUM_APP_URL when set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sign in with Google: only these emails can log in (comma- or space-separated). Leave empty to disable.
# ALLOWED_GOOGLE_EMAILS=admin@company.com,dev@company.com
# DEFAULT_GOOGLE_SIGNIN_ROLE=DEVELOPER   (role for new users on first Google sign-in; default DEVELOPER)

# App URL — used for Google OAuth redirect_uri when set (required behind proxy/CDN so it matches Google Console). No trailing slash.
# NEXIUM_APP_URL=https://workspace.onenexium.com
# NEXIUM_APP_URL=http://localhost:3000
# Also used to resolve the public origin for laptop agents (Workstation module → Cloud API card). Set in production.

# Optional: browser-visible base URL fallback (e.g. for client-only reads)
# NEXT_PUBLIC_APP_URL=https://workspace.onenexium.com

# Optional: encrypt mail account credentials (tokens, SMTP passwords)
ENCRYPTION_KEY=

# AI Terminal (natural language → command). First available is used:
# GEMINI_API_KEY=...        (Google AI Studio / Gemini API key; recommended)
# GOOGLE_API_KEY=...        (alternative env name for Gemini)
# GEMINI_MODEL=gemini-2.5-flash   (optional; default gemini-2.5-flash)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# AI Terminal execution: if the app runs where aws/docker are not installed (e.g. Vercel), set SSH to run commands on a host that has them (e.g. Platform EC2).
# All three required for remote execution; otherwise commands run on the same machine as the app.
# TERMINAL_SSH_HOST=13.206.23.228
# TERMINAL_SSH_USER=ec2-user
# TERMINAL_SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"
# TERMINAL_SSH_PORT=22

# ─── Infrastructure (AWS) — required for Infrastructure module & Command Centre widget ───
# Use credentials with read-only + ec2:StartInstances/StopInstances for full status + start/stop.
# Copy from Onenexium_aws_setup/onenexium-infra-vars.env as needed.
# AWS_REGION=ap-south-1
# AWS_ACCOUNT_ID=268054298224
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Optional overrides (defaults match Onenexium_aws_setup):
# ONENEXIUM_PLATFORM_INSTANCE_ID=i-081b6335b35bfb292
# ONENEXIUM_RUNTIME_INSTANCE_ID=i-054b26f20ec8c7658
# ONENEXIUM_RDS_INSTANCE_ID=onenexium-platform-db
# ONENEXIUM_REDIS_CLUSTER_ID=onenexium-redis
# ONENEXIUM_ALB_NAME=onenexium-alb
# ONENEXIUM_PLATFORM_TG_ARN=arn:aws:elasticloadbalancing:ap-south-1:268054298224:targetgroup/onenexium-platform-tg/c214d4051da77a39
# ONENEXIUM_ALARM_NAMES=platform-cpu-high,rds-cpu-high,rds-storage-low,rds-connections-high,redis-memory-high
# ONENEXIUM_S3_BUCKET_NAME=onenexium-storage-268054298224
# ONENEXIUM_ECR_REPO=onenexium/user-apps
